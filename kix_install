#!/bin/bash

# 1. VARIÁVEIS DE INSTÂNCIA
ID=${1:-2}
BASE_DIR="$HOME/KIX_PROTOTIPO$ID"
PORT_DASH=$((3000 + ID))
PORT_ENGINE=$((5000 + ID))
PORT_VAULT=$((8080 + ID))

# 2. CAPTURA DO IP (Prioriza Tailscale, depois IP Local)
IP_PARA_LINKS=$(ip addr show tailscale0 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}' || hostname -I | awk '{print $1}')

echo "🛠️ Instalando KIX v$ID..."
echo "🌐 IP detectado para os links: $IP_PARA_LINKS"

# 3. CRIAR PASTAS COM PERMISSÃO
sudo mkdir -p "$BASE_DIR/homepage/config" "$BASE_DIR/data/lnbits" "$BASE_DIR/data/alby"

# 4. CRIAR O DOCKER-COMPOSE
cat <<EOF | sudo tee "$BASE_DIR/docker-compose.yml" > /dev/null
services:
  kix-dash-v$ID:
    image: ghcr.io/gethomepage/homepage:latest
    container_name: kix-dash-v$ID
    restart: unless-stopped
    pull_policy: if_not_present
    ports:
      - "$PORT_DASH:3000"
    volumes:
      - ./homepage/config:/app/config
    environment:
      - HOMEPAGE_ALLOWED_HOSTS=*

  kix-engine-v$ID:
    image: lnbits/lnbits:latest
    container_name: kix-engine-v$ID
    restart: unless-stopped
    pull_policy: if_not_present
    ports:
      - "$PORT_ENGINE:5000"
    env_file:
      - .env
    volumes:
      - ./data/lnbits:/app/data

  kix-vault-v$ID:
    image: ghcr.io/getalby/hub:latest
    container_name: kix-vault-v$ID
    restart: unless-stopped
    pull_policy: if_not_present
    ports:
      - "$PORT_VAULT:8080"
    volumes:
      - ./data/alby:/data
EOF

# 5. CONFIGURAR LINKS DO DASHBOARD (IP FIXO INJETADO)
cat <<EOF | sudo tee "$BASE_DIR/homepage/config/services.yaml" > /dev/null
- Grupo KIX v$ID:
    - Engine (LNbits):
        icon: lnbits.png
        href: "http://$IP_PARA_LINKS:$PORT_ENGINE"
        description: "Processador de Pagamentos"
    - Vault (Alby):
        icon: alby.png
        href: "http://$IP_PARA_LINKS:$PORT_VAULT"
        description: "Cofre de Chaves"
EOF

# 6. SETTINGS E VISUAL
echo "title: KIX v$ID" | sudo tee "$BASE_DIR/homepage/config/settings.yaml" > /dev/null
echo "background: '#0a0a0a'" | sudo tee -a "$BASE_DIR/homepage/config/settings.yaml" > /dev/null

# 7. CONFIGURAÇÃO LNBITS (.ENV)
cat <<EOF | sudo tee "$BASE_DIR/.env" > /dev/null
LNBITS_BACKEND_WALLET_CLASS=VoidWallet
LNBITS_DATA_FOLDER=./data
HOST=0.0.0.0
PORT=5000
EOF

# 8. SUBIR O SISTEMA
cd "$BASE_DIR"
sudo docker compose up -d --pull missing

echo "------------------------------------------------"
echo "✅ KIX v$ID instalado com sucesso!"
echo "Acesse o Dashboard: http://$IP_PARA_LINKS:$PORT_DASH"
echo "------------------------------------------------"
